" Smallest config I need on all machines at all times.

" Moves for editing from the beginning and until the end of the line
noremap L g_
noremap H ^

" Navigating open buffers
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <C-p> <C-w>p

" Copying and pasting
noremap <space> "+


" Relative lines
set number relativenumber
set splitbelow splitright
